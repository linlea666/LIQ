# AI API (按 config.yaml 中 ai.active 选择的 provider 配置对应 key)
# OpenAI
OPENAI_API_KEY=sk-xxx
# DeepSeek
DEEPSEEK_API_KEY=sk-xxx
# 兼容旧配置: 如果上面对应的 key 为空, 会 fallback 到这个
AI_API_KEY=

# OKX (optional, for private endpoints)
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Redis (optional, defaults to localhost)
REDIS_URL=redis://localhost:6379/0
